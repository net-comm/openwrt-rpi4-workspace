# OpenWrt Raspberry Pi 4 starter build configuration
# Generated from: make defconfig (bcm27xx/bcm2711 target)
# Copy this file to the OpenWrt source tree root as .config, then run:
#   make defconfig   (expands defaults)
#   make menuconfig  (optional: fine-tune interactively)
#   make -j$(nproc)

# -----------------------------------------------------------------------
# Target platform — Raspberry Pi 4 (Broadcom BCM2711, ARM Cortex-A72)
# -----------------------------------------------------------------------
CONFIG_TARGET_bcm27xx=y
CONFIG_TARGET_bcm27xx_bcm2711=y
CONFIG_TARGET_bcm27xx_bcm2711_DEVICE_rpi-4=y

# -----------------------------------------------------------------------
# Filesystem: prefer ext4 (easier to resize on SD card)
# -----------------------------------------------------------------------
CONFIG_TARGET_ROOTFS_EXT4FS=y
# CONFIG_TARGET_ROOTFS_SQUASHFS is not set

# -----------------------------------------------------------------------
# Image types: factory SD card image
# -----------------------------------------------------------------------
CONFIG_TARGET_IMAGES_GZIP=y

# -----------------------------------------------------------------------
# Kernel modules — WiFi (onboard BCM43455 via SDIO)
# -----------------------------------------------------------------------
CONFIG_PACKAGE_kmod-brcmfmac=y
CONFIG_PACKAGE_brcmfmac-firmware-43455-sdio=y
CONFIG_PACKAGE_hostapd-common=y
CONFIG_PACKAGE_wpad-basic-mbedtls=y

# -----------------------------------------------------------------------
# Kernel modules — USB support
# -----------------------------------------------------------------------
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-asix=y
CONFIG_PACKAGE_kmod-usb-net-asix-ax88179=y
CONFIG_PACKAGE_kmod-usb-net-rtl8152=y

# -----------------------------------------------------------------------
# Basic networking packages
# -----------------------------------------------------------------------
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_cgi-io=y
CONFIG_PACKAGE_luci-theme-netcomm=y
# CONFIG_PACKAGE_luci-theme-bootstrap is not set
CONFIG_PACKAGE_luci-app-watchdog=y
CONFIG_PACKAGE_luci-app-congestion-monitor=y
CONFIG_PACKAGE_intruder-alert=y
CONFIG_PACKAGE_luci-app-intruder-alert=y
CONFIG_PACKAGE_rest-api-app=y
CONFIG_PACKAGE_luci-lib-nixio=y
CONFIG_PACKAGE_lua=y
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_dnsmasq=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_kmod-nft-offload=y

# -----------------------------------------------------------------------
# Utilities
# -----------------------------------------------------------------------
CONFIG_PACKAGE_curl=y

# -----------------------------------------------------------------------
# SSH / administration
# -----------------------------------------------------------------------
CONFIG_PACKAGE_openssh-sftp-server=y

# -----------------------------------------------------------------------
# Build options
# -----------------------------------------------------------------------
CONFIG_DEVEL=y
CONFIG_BUILD_LOG=y
